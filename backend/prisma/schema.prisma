generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  sales_manager
  product_manager
}

enum OrderStatus {
  processing
  in_transit
  delivered
}

enum CommentStatus {
  pending
  approved
  rejected
}

model User {
  id                         Int      @id @default(autoincrement())
  name                       String
  email                      String   @unique
  passwordHash               String   @map("password_hash")
  passwordChangeCode         String?  @map("password_change_code")
  passwordChangeCodeExpiresAt DateTime? @map("password_change_code_expires_at")
  passwordChangeNewHash      String?  @map("password_change_new_hash")
  role                       Role     @default(customer)
  /// Story 14: nullable JSON default delivery address snapshot.
  /// Shape: { fullName, line1, line2?, city, postalCode, country }
  defaultAddress             Json?    @map("default_address")
  createdAt                  DateTime @default(now()) @map("created_at")

  savedCards    SavedCard[]
  cartItems     CartItem[]
  orders        Order[]
  addresses     UserAddress[]
  wishlists     Wishlist[]
  ratings       Rating[]
  comments      Comment[]

  @@map("users")
}

model UserAddress {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  label      String
  fullName   String   @map("full_name")
  line1      String
  line2      String   @default("")
  city       String
  postalCode String   @map("postal_code")
  country    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])
  @@index([userId])
  @@map("user_addresses")
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String
  description     String   @default("")
  price           Decimal  @db.Decimal(10, 2)
  discount        Decimal  @default(0) @db.Decimal(5, 2)
  discountName    String?  @map("discount_name")
  discountType    String?  @map("discount_type")
  discountStartsAt DateTime? @map("discount_starts_at")
  discountEndsAt  DateTime? @map("discount_ends_at")
  stockQty        Int      @default(0) @map("stock_qty")
  sku             String   @unique
  imageUrl        String   @default("") @map("image_url")
  category        String   @default("")
  model           String   @default("")
  serialNumber    String   @unique @map("serial_number")
  warrantyStatus  String   @default("None") @map("warranty_status")
  distributorInfo String   @default("") @map("distributor_info")
  avgRating       Float    @default(0) @map("avg_rating")
  ratingCount     Int      @default(0) @map("rating_count")
  createdAt       DateTime @default(now()) @map("created_at")

  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  ratings       Rating[]
  comments      Comment[]

  @@index([category])
  @@index([name])
  @@map("products")
}

model SavedCard {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  label              String
  cardholderFullName String   @map("cardholder_name")
  cardNumber         String   @map("card_number")
  cvv                String   @default("")
  last4              String   @map("last_four")
  expiry             String
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])
  @@index([userId])
  @@map("user_cards")
}

model CartItem {
  id        Int @id @default(autoincrement())
  userId    Int @map("user_id")
  productId Int @map("product_id")
  quantity  Int @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

/// Story 16: Order stores snapshots so history is immutable.
/// address is a JSON blob ready for Story 14 expansion:
/// { fullName, line1, line2?, city, postalCode, country }
model Order {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  totalAmount Decimal     @db.Decimal(10, 2) @map("total_amount")
  status      OrderStatus @default(processing)
  address     Json        @default("{}")
  invoiceNo   String?     @unique @map("invoice_no")
  createdAt   DateTime    @default(now()) @map("created_at")

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@map("orders")
}

/// Snapshot of product info at time of purchase — immune to later edits.
model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int     @map("order_id")
  productId   Int     @map("product_id")
  productName String  @map("product_name")
  unitPrice   Decimal @db.Decimal(10, 2) @map("unit_price")
  quantity    Int
  lineTotal   Decimal @db.Decimal(10, 2) @map("line_total")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@unique([userId, name])
  @@index([userId])
  @@map("wishlists")
}

/// Wishlist: members-only, supports add/remove. Out-of-stock products allowed.
model WishlistItem {
  id        Int      @id @default(autoincrement())
  wishlistId Int     @map("wishlist_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@map("wishlist_items")
}

/// Rating: 1-5 stars, one per user per product. Only if product purchased & order delivered.
model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  value     Int
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("ratings")
}

/// Comment: pending by default, visible only when approved. Independent from rating.
model Comment {
  id        Int           @id @default(autoincrement())
  userId    Int           @map("user_id")
  productId Int           @map("product_id")
  text      String
  status    CommentStatus @default(pending)
  createdAt DateTime      @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("comments")
}
